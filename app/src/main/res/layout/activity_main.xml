<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="64dp"
            android:layout_height="72dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="18dp"
            android:contentDescription="Logo Banco"
            android:scaleType="fitCenter"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/logo_banco_pichincha" />

        <TextView
            android:id="@+id/txtBanco"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="sans-serif-medium"
            android:lineSpacingExtra="-2dp"
            android:text="BANCO\nPICHINCHA"
            android:textColor="#0D2B63"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/imgLogo"
            app:layout_constraintStart_toEndOf="@id/imgLogo"
            app:layout_constraintTop_toTopOf="@id/imgLogo" />

        <LinearLayout
            android:id="@+id/layoutAyuda"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:layout_marginEnd="22dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/support_contact"
                app:tint="#0D2B63" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="sans-serif-medium"
                android:text="Ayuda"
                android:textColor="#0D2B63"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="sans-serif"
            android:text="Versión: 9.5.0"
            android:textColor="#8A8A8A"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imgLogo" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardImage"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="20dp"
            app:cardBackgroundColor="#F8F8F8"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtVersion">

            <ImageView
                android:id="@+id/imgPareja"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="24dp"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/pareja_banco_pichincha" />

        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQR"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:backgroundTint="@android:color/white"
            android:elevation="0dp"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="Ver mi QR"
            android:textAllCaps="false"
            android:textColor="#1B2E66"
            android:textSize="14sp"
            android:textStyle="bold"
            android:translationY="24dp"
            app:cornerRadius="18dp"
            app:icon="@drawable/sincronizacion"
            app:iconGravity="textEnd"
            app:iconPadding="8dp"
            app:iconSize="18dp"
            app:iconTint="#7A59C3"
            app:layout_constraintBottom_toBottomOf="@id/cardImage"
            app:layout_constraintEnd_toEndOf="@id/cardImage"
            app:layout_constraintStart_toStartOf="@id/cardImage"
            app:rippleColor="#EEEEEE"
            app:strokeColor="#DDDDDD"
            app:strokeWidth="1dp" />

        <LinearLayout
            android:id="@+id/topOptions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="52dp"
            android:layout_marginEnd="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnQR">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/circle_background"
                    android:padding="18dp"
                    android:src="@drawable/shield"
                    app:tint="#102A5E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:lineSpacingExtra="-2dp"
                    android:text="Verificar\ntransferencia"
                    android:textColor="#102A5E"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/circle_background"
                    android:padding="18dp"
                    android:src="@drawable/location"
                    app:tint="#102A5E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:lineSpacingExtra="-2dp"
                    android:text="Pagar\ncon QR"
                    android:textColor="#102A5E"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/circle_background"
                    android:padding="18dp"
                    android:src="@drawable/key"
                    app:tint="#102A5E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:lineSpacingExtra="-2dp"
                    android:text="Clave\nDigital"
                    android:textColor="#102A5E"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/loginOptions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="26dp"
            android:layout_marginEnd="16dp"
            android:orientation="horizontal"
            android:weightSum="3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/topOptions">

            <com.google.android.material.button.MaterialButton
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:backgroundTint="@android:color/white"
                android:elevation="0dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="10dp"
                android:text="Usuario y\ncontraseña"
                android:textAllCaps="false"
                android:textColor="#102A5E"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@drawable/profile"
                app:iconGravity="top"
                app:iconPadding="10dp"
                app:iconSize="36dp"
                app:iconTint="#102A5E"
                app:rippleColor="#EEEEEE"
                app:strokeColor="#E3E6EC"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:backgroundTint="@android:color/white"
                android:elevation="0dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="10dp"
                android:text="Huella /\nFace ID"
                android:textAllCaps="false"
                android:textColor="#102A5E"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@drawable/fingerprint"
                app:iconGravity="top"
                app:iconPadding="10dp"
                app:iconSize="36dp"
                app:iconTint="#102A5E"
                app:rippleColor="#EEEEEE"
                app:strokeColor="#E3E6EC"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_margin="6dp"
                android:layout_weight="1"
                android:backgroundTint="@android:color/white"
                android:elevation="0dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="10dp"
                android:text="Pin de\n6 dígitos"
                android:textAllCaps="false"
                android:textColor="#102A5E"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@drawable/password"
                app:iconGravity="top"
                app:iconPadding="10dp"
                app:iconSize="36dp"
                app:iconTint="#102A5E"
                app:rippleColor="#EEEEEE"
                app:strokeColor="#E3E6EC"
                app:strokeWidth="1dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtOtroUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="¿Ingresar con otro usuario?"
            android:textColor="#1294B8"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.498"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/loginOptions" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>